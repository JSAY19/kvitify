# ===== БД =====
POSTGRES_USER=kvitifai
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_DB=kvitifai
# Используется сервером внутри docker network (имя сервиса = db)
DATABASE_URL="postgresql://kvitifai:change-me-strong-password@db:5432/kvitifai?schema=public"

# ===== JWT (по 64+ символа каждый, можно сгенерировать: openssl rand -hex 48) =====
JWT_SECRET=replace-with-64-char-random-string-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=replace-with-another-64-char-random-string-xxxxxxxxxxxxxxxxxxxxxx

# ===== GigaChat (Sber) =====
GIGACHAT_CREDENTIALS=your_base64_credentials
# В проде НУЦ Минцифры не доверен Node по умолчанию — оставь true пока не настроишь CA bundle
GIGACHAT_ALLOW_INSECURE=true

# ===== URL =====
# Публичный URL фронтенда (для CORS/CSP/CSRF)
CLIENT_URL=https://example.com
# Доп. разрешённые origin'ы через запятую (например, прод + стейдж)
CLIENT_URLS=

# ===== Web Push (опционально) =====
# Сгенерировать пару: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ===== Сервер =====
NODE_ENV=production
HOST=0.0.0.0
PORT=3001

# ===== docker-compose =====
# Внешний порт nginx-клиента
CLIENT_PORT=80
